<!-- Order Received Email Template (Table-based, Responsive) -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Order Received - eShopper Luxe</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
</head>
<body style="margin:0; padding:0; background:#181818; color:#fff; font-family:'Segoe UI',Arial,sans-serif;">
  <table width="100%" bgcolor="#181818" cellpadding="0" cellspacing="0" style="padding:0; margin:0;">
    <tr>
      <td align="center">
        <table width="480" cellpadding="0" cellspacing="0" style="background:#232323; border-radius:12px; margin:32px 0; box-shadow:0 2px 16px #00000033;">
          <!-- Header -->
          <tr>
            <td style="padding:24px 32px 8px 32px; text-align:left;">
              <img src="https://yourdomain.com/logo.png" alt="eShopper Luxe" style="height:28px; margin-bottom:12px;">
              <div style="font-size:13px; color:#ffd700; text-align:right; float:right;">ORDER ID<br><span style="color:#fff; font-weight:600;">{{orderId}}</span></div>
            </td>
          </tr>
          <!-- Order Received Banner -->
          <tr>
            <td style="background:#ffd700; color:#232323; text-align:center; font-size:22px; font-weight:600; padding:18px 0 10px 0; letter-spacing:1px;">
              &#10003; ORDER RECEIVED
              <div style="font-size:13px; color:#232323; font-weight:400; margin-top:2px;">{{orderDate}}</div>
            </td>
          </tr>
          <!-- Greeting -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:left;">
              <div style="font-size:18px; font-weight:600; margin-bottom:6px;">Hi {{customerName}},</div>
              <div style="font-size:14px; color:#ccc;">Your luxury selection is now in our queue. We are verifying your items and preparing them for dispatch.</div>
              <div style="margin:12px 0 0 0;">
                <span style="background:#1a3d1a; color:#b6ffb6; font-size:13px; padding:4px 12px; border-radius:6px; display:inline-block;">&#10003; Payment Received &amp; Verified</span>
              </div>
            </td>
          </tr>
          <!-- Order Summary -->
          <tr>
            <td style="padding:24px 32px 0 32px;">
              <div style="color:#ffd700; font-size:15px; font-weight:600; margin-bottom:8px;">ORDER SUMMARY</div>
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#232323; border-radius:8px;">
                <tr style="color:#ffd700; font-size:13px;">
                  <th align="left" style="padding:8px 0;">ITEM</th>
                  <th align="left" style="padding:8px 0;">DETAILS</th>
                  <th align="center" style="padding:8px 0;">QTY</th>
                  <th align="right" style="padding:8px 0;">PRICE</th>
                </tr>
                <tr style="background:#181818;">
                  <td style="padding:8px 0;">
                    <img src="{{productImage}}" alt="Product" style="width:48px; border-radius:6px;">
                  </td>
                  <td style="padding:8px 0;">
                    <div style="font-weight:600; color:#fff;">{{productName}}</div>
                    <div style="font-size:12px; color:#ccc;">Size: {{size}}</div>
                    <div style="font-size:12px; color:#ccc;">Color: {{color}}</div>
                  </td>
                  <td align="center" style="padding:8px 0; color:#fff;">{{qty}}</td>
                  <td align="right" style="padding:8px 0; color:#fff;">₹{{price}}</td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Shipping & Payment -->
          <tr>
            <td style="padding:18px 32px 0 32px;">
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td valign="top" width="55%" style="padding-right:12px;">
                    <table width="100%" style="background:#232323; border-radius:8px;">
                      <tr>
                        <td style="color:#ffd700; font-size:13px; font-weight:600; padding:8px 0 0 0;">&#128205; SHIPPING TO</td>
                      </tr>
                      <tr>
                        <td style="color:#fff; font-size:14px; font-weight:600;">{{customerName}}</td>
                      </tr>
                      <tr>
                        <td style="color:#b6b6b6; font-size:13px;">
                          {{address}}<br>
                          {{city}}, {{state}} {{zip}}<br>
                          <span style="color:#ffd700;">&#128222;</span> {{phone}}
                        </td>
                      </tr>
                    </table>
                  </td>
                  <td valign="top" width="45%">
                    <table width="100%" style="background:#232323; border-radius:8px;">
                      <tr>
                        <td style="color:#ffd700; font-size:13px; font-weight:600; padding:8px 0 0 0;">PAYMENT METHOD</td>
                      </tr>
                      <tr>
                        <td style="color:#fff; font-size:14px;">{{paymentMethod}}</td>
                      </tr>
                      <tr>
                        <td style="color:#b6ffb6; font-size:13px;">Status: <span style="color:#00ff66;">{{paymentStatus}}</span></td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Price Summary -->
          <tr>
            <td style="padding:18px 32px 0 32px;">
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="color:#b6b6b6; font-size:14px;">Subtotal</td>
                  <td align="right" style="color:#fff; font-size:14px;">₹{{subtotal}}</td>
                </tr>
                <tr>
                  <td style="color:#b6b6b6; font-size:14px;">Shipping</td>
                  <td align="right" style="color:#fff; font-size:14px;">{{shipping}}</td>
                </tr>
                <tr>
                  <td style="color:#ffd700; font-size:16px; font-weight:600; padding-top:8px;">Total Amount</td>
                  <td align="right" style="color:#ffd700; font-size:16px; font-weight:600; padding-top:8px;">₹{{total}}</td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- View Order Status Button -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:center;">
              <a href="{{orderStatusUrl}}" style="background:#ffd700; color:#232323; font-size:16px; font-weight:600; text-decoration:none; padding:12px 32px; border-radius:8px; display:inline-block;">VIEW ORDER STATUS</a>
            </td>
          </tr>
          <!-- Note -->
          <tr>
            <td style="padding:12px 32px 0 32px; color:#b6b6b6; font-size:12px; text-align:left;">
              * This is an order receipt, not a Tax Invoice. Tax Invoice will be provided upon delivery.
            </td>
          </tr>
          <!-- Concierge Section -->
          <tr>
            <td style="padding:32px 0 0 0;">
              <table width="100%" style="background:#2a230e; border-radius:0 0 12px 12px;">
                <tr>
                  <td style="text-align:center; padding:24px 0 0 0;">
                    <span style="font-size:32px;">👑</span>
                  </td>
                </tr>
                <tr>
                  <td style="text-align:center; color:#ffd700; font-size:20px; font-weight:600; padding:8px 0 0 0;">Personal Concierge</td>
                </tr>
                <tr>
                  <td style="text-align:center; color:#fff; font-size:14px; padding:8px 32px 0 32px;">
                    Our dedicated team is here to assist with any questions about your order. Reach out anytime!
                  </td>
                </tr>
                <tr>
                  <td style="text-align:center; padding:18px 0 24px 0;">
                    <a href="{{whatsappUrl}}" style="background:#25d366; color:#232323; font-size:15px; font-weight:600; text-decoration:none; padding:10px 24px; border-radius:6px; margin-right:8px; display:inline-block;">&#128172; WHATSAPP SUPPORT</a>
                    <a href="{{emailUrl}}" style="background:#232323; color:#fff; font-size:15px; font-weight:600; text-decoration:none; padding:10px 24px; border-radius:6px; border:1px solid #fff; display:inline-block;">&#128231; EMAIL US</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td style="padding:24px 0 0 0; text-align:center; color:#b6b6b6; font-size:12px;">
              © 2026 eShopper Luxe. All rights reserved.<br>
              Shop 3, Sahid Marg, Near Power, Lucknow - 226001, UP, India<br>
              <a href="{{privacyUrl}}" style="color:#ffd700; text-decoration:none;">Privacy Policy</a> | <a href="{{termsUrl}}" style="color:#ffd700; text-decoration:none;">Terms of Service</a>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>