<!-- Order Packed Email Template (Table-based, Responsive) -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Order Packed - eShopper Luxe</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
</head>
<body style="margin:0; padding:0; background:#181818; color:#fff; font-family:'Segoe UI',Arial,sans-serif;">
  <table width="100%" bgcolor="#181818" cellpadding="0" cellspacing="0" style="padding:0; margin:0;">
    <tr>
      <td align="center">
        <table width="480" cellpadding="0" cellspacing="0" style="background:#232323; border-radius:12px; margin:32px 0; box-shadow:0 2px 16px #00000033;">
          <!-- Header -->
          <tr>
            <td style="padding:24px 32px 8px 32px; text-align:left;">
              <img src="https://yourdomain.com/logo.png" alt="eShopper Luxe" style="height:28px; margin-bottom:12px;">
              <div style="font-size:13px; color:#fff; text-align:right; float:right;">
                <span style="background:#a259e6; color:#fff; font-size:13px; padding:4px 12px; border-radius:6px; font-weight:600;">&#128230; PACKED</span>
              </div>
            </td>
          </tr>
          <!-- Packed Banner -->
          <tr>
            <td style="background:#a259e6; color:#fff; text-align:center; font-size:22px; font-weight:600; padding:18px 0 10px 0; letter-spacing:1px;">
              <span style="font-size:22px;">📦</span> WRAPPED WITH CARE
              <div style="font-size:13px; color:#eae2fa; font-weight:400; margin-top:2px;">
                Your luxe package is ready!
              </div>
            </td>
          </tr>
          <!-- Greeting -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:left;">
              <div style="font-size:18px; font-weight:600; margin-bottom:6px;">Hi {{customerName}} <span style="font-size:18px;">🎉</span></div>
              <div style="font-size:14px; color:#ccc;">
                Great news! Your order has been <span style="color:#a259e6; font-weight:600;">sanitized</span>, <span style="color:#a259e6; font-weight:600;">quality-checked</span>, and carefully packed in our signature <span style="color:#ffd700; font-weight:600;">eco-friendly luxe box</span>. Your premium items are protected and ready for their journey!
              </div>
            </td>
          </tr>
          <!-- Quality Inspected -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:center;">
              <div style="background:#232323; border-radius:50%; width:80px; height:80px; margin:0 auto;">
                <div style="background:#1bbf4c; color:#fff; font-size:15px; font-weight:700; border-radius:50%; width:80px; height:80px; display:flex; align-items:center; justify-content:center; margin:0 auto;">
                  QUALITY<br>INSPECTED
                </div>
              </div>
            </td>
          </tr>
          <!-- Package Summary -->
          <tr>
            <td style="padding:24px 32px 0 32px;">
              <div style="color:#b983ff; font-size:15px; font-weight:600; margin-bottom:8px;">PACKAGE SUMMARY</div>
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#232323; border-radius:8px;">
                <tr>
                  <td style="color:#fff; font-size:14px; padding:8px 0;">Order ID</td>
                  <td align="right" style="color:#fff; font-size:14px; padding:8px 0;">{{orderId}}</td>
                </tr>
                <tr>
                  <td style="color:#fff; font-size:14px; padding:8px 0;">Total Items</td>
                  <td align="right" style="color:#fff; font-size:14px; padding:8px 0;">{{totalItems}}</td>
                </tr>
                <tr>
                  <td style="color:#fff; font-size:14px; padding:8px 0;">Packed On</td>
                  <td align="right" style="color:#fff; font-size:14px; padding:8px 0;">{{packedOn}}</td>
                </tr>
                <tr>
                  <td style="color:#fff; font-size:14px; padding:8px 0;">Package Weight</td>
                  <td align="right" style="color:#b983ff; font-size:14px; padding:8px 0;">{{packageWeight}}</td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Eco-Luxe Packaging -->
          <tr>
            <td style="padding:24px 32px 0 32px;">
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#143d1a; border-radius:8px;">
                <tr>
                  <td colspan="4" style="color:#b6ffb6; font-size:15px; font-weight:600; text-align:center; padding:12px 0 0 0;">
                    🌿 ECO-LUXE PACKAGING
                  </td>
                </tr>
                <tr>
                  <td align="center" style="padding:16px 0;">
                    <img src="https://img.icons8.com/ios-filled/50/25d366/recycle.png" width="32" style="display:block; margin:0 auto 6px auto;">
                    <div style="color:#fff; font-size:13px; font-weight:600;">100% Recyclable</div>
                  </td>
                  <td align="center" style="padding:16px 0;">
                    <img src="https://img.icons8.com/ios-filled/50/25d366/shield.png" width="32" style="display:block; margin:0 auto 6px auto;">
                    <div style="color:#fff; font-size:13px; font-weight:600;">Bubble Wrapped</div>
                  </td>
                  <td align="center" style="padding:16px 0;">
                    <img src="https://img.icons8.com/ios-filled/50/25d366/soap.png" width="32" style="display:block; margin:0 auto 6px auto;">
                    <div style="color:#fff; font-size:13px; font-weight:600;">Sanitized Packaging</div>
                  </td>
                  <td align="center" style="padding:16px 0;">
                    <img src="https://img.icons8.com/ios-filled/50/25d366/diamond.png" width="32" style="display:block; margin:0 auto 6px auto;">
                    <div style="color:#fff; font-size:13px; font-weight:600;">Premium Sealant</div>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- What's Next -->
          <tr>
            <td style="padding:24px 32px 0 32px;">
              <div style="color:#ffd700; font-size:15px; font-weight:600; margin-bottom:8px;">📍 WHAT'S NEXT?</div>
              <div style="color:#fff; font-size:14px;">
                Your package will leave our warehouse within <span style="font-weight:700;">24-48 hours</span>. You'll receive a <span style="color:#b983ff; text-decoration:underline;">tracking link via email &amp; SMS</span> as soon as it's dispatched.
              </div>
              <table width="100%" cellpadding="0" cellspacing="0" style="margin-top:16px;">
                <tr>
                  <td align="center" style="color:#25d366; font-size:32px;">&#10003;</td>
                  <td align="center" style="color:#25d366; font-size:32px;">&#10003;</td>
                  <td align="center" style="color:#b983ff; font-size:32px;">&#128230;</td>
                  <td align="center" style="color:#ffd700; font-size:32px;">&#128230;</td>
                </tr>
                <tr>
                  <td align="center" style="color:#fff; font-size:13px;">PLACED</td>
                  <td align="center" style="color:#fff; font-size:13px;">CONFIRMED</td>
                  <td align="center" style="color:#fff; font-size:13px;">PACKED</td>
                  <td align="center" style="color:#fff; font-size:13px;">SHIPPED</td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Shipping Address -->
          <tr>
            <td style="padding:24px 32px 0 32px;">
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#232323; border-radius:8px;">
                <tr>
                  <td style="color:#ffd700; font-size:13px; font-weight:600; padding:8px 0 0 0;">&#128205; SHIPPING ADDRESS</td>
                </tr>
                <tr>
                  <td style="color:#fff; font-size:14px; font-weight:600;">{{customerName}}</td>
                </tr>
                <tr>
                  <td style="color:#b6b6b6; font-size:13px;">
                    {{address}}<br>
                    {{city}}, {{state}} {{zip}}<br>
                    Phone: {{phone}}
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Track Package Button -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:center;">
              <a href="{{trackPackageUrl}}" style="background:#b983ff; color:#232323; font-size:16px; font-weight:600; text-decoration:none; padding:12px 32px; border-radius:8px; display:inline-block; margin-bottom:8px;">🔍 TRACK PACKAGE</a>
              <div style="color:#ffd700; font-size:12px; margin-top:8px;">💡 Pro Tip: Enable notifications to get real-time updates!</div>
            </td>
          </tr>
          <!-- Need Help -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:center;">
              <div style="color:#b6b6b6; font-size:14px; margin-bottom:8px;">Have Questions?</div>
              <a href="{{whatsappUrl}}" style="background:#25d366; color:#232323; font-size:15px; font-weight:600; text-decoration:none; padding:10px 24px; border-radius:6px; margin-right:8px; display:inline-block;">WhatsApp Support</a>
              <a href="{{instagramUrl}}" style="background:#ff2d55; color:#fff; font-size:15px; font-weight:600; text-decoration:none; padding:10px 24px; border-radius:6px; display:inline-block;">Instagram</a>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td style="padding:24px 0 0 0; text-align:center; color:#b6b6b6; font-size:12px;">
              © 2026 eShopper Luxe. All rights reserved.<br>
              Shop 3, Sahid Marg, Near Power, Lucknow - 226001, UP, India<br>
              <a href="{{privacyUrl}}" style="color:#ffd700; text-decoration:none;">Privacy</a> | <a href="{{termsUrl}}" style="color:#ffd700; text-decoration:none;">Terms</a>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>