<!-- Order Out for Delivery / Arriving Today Email Template (Table-based, Responsive) -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Arriving Today - eShopper Luxe</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
</head>
<body style="margin:0; padding:0; background:#181818; color:#fff; font-family:'Segoe UI',Arial,sans-serif;">
  <table width="100%" bgcolor="#181818" cellpadding="0" cellspacing="0" style="padding:0; margin:0;">
    <tr>
      <td align="center">
        <table width="480" cellpadding="0" cellspacing="0" style="background:#232323; border-radius:12px; margin:32px 0; box-shadow:0 2px 16px #00000033;">
          <!-- Header -->
          <tr>
            <td style="padding:24px 32px 8px 32px; text-align:left;">
              <img src="https://yourdomain.com/logo.png" alt="eShopper Luxe" style="height:28px; margin-bottom:12px;">
              <div style="font-size:13px; color:#fff; text-align:right; float:right;">
                <span style="background:#ff9800; color:#fff; font-size:13px; padding:4px 12px; border-radius:6px; font-weight:600;">🚚 OUT FOR DELIVERY</span>
              </div>
            </td>
          </tr>
          <!-- Arriving Today Banner -->
          <tr>
            <td style="background:#ff9800; color:#fff; text-align:center; font-size:22px; font-weight:600; padding:18px 0 10px 0; letter-spacing:1px;">
              <span style="font-size:22px;">🎁</span> IT'S ARRIVING TODAY!
              <div style="font-size:13px; color:#fffde7; font-weight:400; margin-top:2px;">
                Your luxury package is just minutes away
              </div>
            </td>
          </tr>
          <!-- Delivery in Progress -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:center;">
              <div style="background:#232323; border:2px solid #ff9800; border-radius:8px; padding:12px 0;">
                <span style="background:#ff9800; color:#232323; font-size:13px; font-weight:600; border-radius:6px; padding:4px 12px;">⏰ DELIVERY IN PROGRESS</span>
                <div style="color:#fff; font-size:22px; font-weight:700; margin:8px 0 0 0;">TODAY</div>
                <div style="color:#ffd700; font-size:13px; margin-top:2px;">Expected by {{expectedTime}}</div>
              </div>
            </td>
          </tr>
          <!-- Greeting -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:left;">
              <div style="font-size:18px; font-weight:600; margin-bottom:6px;">Hi {{customerName}} <span style="font-size:18px;">✨</span></div>
              <div style="font-size:14px; color:#ccc;">
                Your luxury package is <span style="color:#ff9800; font-weight:600;">out for delivery</span> and will reach you today!<br>
                Our delivery partner is on the way to your doorstep.
              </div>
            </td>
          </tr>
          <!-- Security Alert -->
          <tr>
            <td style="padding:24px 32px 0 32px;">
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#b71c1c; border-radius:8px;">
                <tr>
                  <td style="color:#ffd700; font-size:15px; font-weight:600; padding:8px 0 0 0;">
                    <span style="font-size:18px;">&#9888;</span> SECURITY FIRST!
                  </td>
                </tr>
                <tr>
                  <td style="color:#fff; font-size:13px; padding:8px 0;">
                    Please share the <b>OTP or verification code ONLY</b> when you receive the package in perfect condition.<br>
                    <span style="color:#ffd700;">Never share OTP before inspecting the package</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Delivery Partner Info -->
          <tr>
            <td style="padding:24px 32px 0 32px;">
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#232323; border-radius:8px; border:2px solid #ff9800;">
                <tr>
                  <td style="color:#ff9800; font-size:15px; font-weight:600; padding:8px 0 0 0;">
                    <span style="font-size:18px;">🚚</span> YOUR DELIVERY PARTNER
                  </td>
                </tr>
                <tr>
                  <td style="color:#b6b6b6; font-size:14px; padding:8px 0;">Courier Partner: <span style="color:#fff;">{{courierPartner}}</span></td>
                </tr>
                <tr>
                  <td style="color:#b6b6b6; font-size:14px; padding:8px 0;">Tracking ID: <span style="color:#ffd700;">{{trackingId}}</span></td>
                </tr>
                <tr>
                  <td style="color:#b6b6b6; font-size:14px; padding:8px 0;">Delivery Agent: <span style="color:#fff;">{{deliveryAgent}}</span></td>
                </tr>
                <tr>
                  <td style="color:#b6b6b6; font-size:14px; padding:8px 0;">Agent Contact: <span style="color:#ffd700;">{{agentContact}}</span></td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Delivery Location -->
          <tr>
            <td style="padding:24px 32px 0 32px;">
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#0d3d2a; border-radius:8px;">
                <tr>
                  <td style="color:#ffd700; font-size:13px; font-weight:600; padding:8px 0 0 0;">&#128205; DELIVERY LOCATION</td>
                </tr>
                <tr>
                  <td style="color:#fff; font-size:14px; font-weight:600;">{{customerName}}</td>
                </tr>
                <tr>
                  <td style="color:#b6b6b6; font-size:13px;">
                    {{address}}<br>
                    {{city}}, {{state}} {{zip}}<br>
                    <span style="color:#ffd700;">&#128222;</span> {{phone}}
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Live Tracking Map -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:center;">
              <div style="background:#232323; border-radius:8px; padding:16px 0;">
                <img src="https://img.icons8.com/ios-filled/50/ff9800/map.png" width="40" style="display:block; margin:0 auto 8px auto;">
                <div style="color:#fff; font-size:14px;">Live tracking map</div>
                <a href="{{liveTrackingUrl}}" style="background:#ff9800; color:#232323; font-size:15px; font-weight:600; text-decoration:none; padding:10px 24px; border-radius:6px; display:inline-block; margin-top:8px;">🗺️ Track Live Location</a>
              </div>
            </td>
          </tr>
          <!-- Change Address & Call Support -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:center;">
              <a href="{{changeAddressUrl}}" style="background:#25d366; color:#232323; font-size:15px; font-weight:600; text-decoration:none; padding:10px 24px; border-radius:6px; margin-right:8px; display:inline-block;">Change Address</a>
              <a href="{{callSupportUrl}}" style="background:#232323; color:#ffd700; font-size:15px; font-weight:600; text-decoration:none; padding:10px 24px; border-radius:6px; border:1px solid #ffd700; display:inline-block;">Call Support</a>
            </td>
          </tr>
          <!-- Before Accepting Delivery -->
          <tr>
            <td style="padding:24px 32px 0 32px;">
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#143d1a; border-radius:8px;">
                <tr>
                  <td style="color:#ffd700; font-size:15px; font-weight:600; padding:8px 0 0 0;">
                    ✔️ BEFORE ACCEPTING DELIVERY
                  </td>
                </tr>
                <tr>
                  <td style="color:#fff; font-size:13px; padding:8px 0;">
                    <ul style="margin:8px 0 0 16px; padding:0;">
                      <li>Check package seal is intact</li>
                      <li>Verify Order ID matches: <span style="color:#ffd700;">{{orderId}}</span></li>
                      <li>Open and inspect items condition</li>
                      <li>Then share OTP/verification code</li>
                    </ul>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Authentic & Insured -->
          <tr>
            <td style="padding:24px 32px 0 32px;">
              <div style="background:#232323; border-radius:8px; padding:12px 0; text-align:center;">
                <span style="background:#143d1a; color:#ffd700; font-size:15px; font-weight:600; border-radius:6px; padding:4px 12px;">🛡️ 100% AUTHENTIC & INSURED</span>
                <div style="color:#fff; font-size:13px; margin-top:4px;">All deliveries are fully insured during transit</div>
              </div>
            </td>
          </tr>
          <!-- Need Help -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:center;">
              <div style="color:#b6b6b6; font-size:14px; margin-bottom:8px;">Questions? We're here to help!</div>
              <a href="{{whatsappUrl}}" style="background:#25d366; color:#232323; font-size:15px; font-weight:600; text-decoration:none; padding:10px 24px; border-radius:6px; margin-right:8px; display:inline-block;">WhatsApp</a>
              <a href="{{instagramUrl}}" style="background:#ff2d55; color:#fff; font-size:15px; font-weight:600; text-decoration:none; padding:10px 24px; border-radius:6px; display:inline-block;">Instagram</a>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td style="padding:24px 0 0 0; text-align:center; color:#b6b6b6; font-size:12px;">
              © 2026 eShopper Luxe. All rights reserved.<br>
              Shop 3, Sahid Marg, Near Power, Lucknow - 226001, UP, India<br>
              <a href="{{privacyUrl}}" style="color:#ffd700; text-decoration:none;">Privacy</a> | <a href="{{termsUrl}}" style="color:#ffd700; text-decoration:none;">Terms</a>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>