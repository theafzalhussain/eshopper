<!--
Ultra-Premium Luxe Email: Order Confirmed
Exact Green Banner, Luxe Promise, and layout as per reference
-->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Confirmed - eShopper Luxe</title>
  <style>
    body { background: #0A0A0A; color: #FFD700; margin: 0; padding: 0; font-family: 'Segoe UI', Arial, sans-serif; }
    .container { max-width: 600px; margin: 0 auto; background: #181818; border-radius: 18px; overflow: hidden; box-shadow: 0 4px 32px #0002; }
    .header { background: linear-gradient(90deg, #0A0A0A 60%, #1ec773 100%); padding: 32px 0 18px 0; text-align: center; }
    .logo { height: 40px; margin-bottom: 12px; }
    .order-title { font-size: 26px; font-weight: 900; color: #fff; letter-spacing: 1.5px; margin: 0; }
    .order-id { font-size: 15px; color: #FFD700; font-weight: 700; margin-top: 6px; }
    .order-date { font-size: 13px; color: #fff; margin-top: 2px; }
    .banner { background: #1ec773; color: #fff; font-size: 20px; font-weight: 900; padding: 16px 0; border-radius: 8px; margin: 24px 0 0 0; letter-spacing: 1px; }
    .greeting { font-size: 18px; color: #fff; margin: 24px 0 0 0; }
    .arrival-box { background: #FFD700; color: #181818; font-size: 18px; font-weight: 900; border-radius: 8px; padding: 12px 0; margin: 24px 0 0 0; letter-spacing: 1px; }
    .promise-row { display: flex; justify-content: space-between; gap: 8px; margin: 28px 0 0 0; }
    .promise { flex: 1; background: #222; border-radius: 12px; padding: 16px 8px; text-align: center; color: #FFD700; }
    .promise-icon { font-size: 28px; margin-bottom: 6px; display: block; }
    .promise-title { font-size: 13px; font-weight: 700; color: #FFD700; margin-bottom: 2px; }
    .promise-desc { color: #fff; font-size: 12px; }
    .summary-title { font-size: 18px; color: #FFD700; font-weight: 700; margin: 32px 0 8px 0; }
    .summary-table { width: 100%; border-collapse: collapse; background: #222; border-radius: 8px; overflow: hidden; }
    .summary-table th, .summary-table td { padding: 12px 8px; text-align: left; }
    .summary-table th { background: #181818; color: #FFD700; font-size: 14px; font-weight: 700; }
    .summary-table td { color: #fff; font-size: 14px; border-bottom: 1px solid #333; }
    .summary-table tr:last-child td { border-bottom: none; }
    .product-img { width: 60px; border-radius: 8px; }
    .total-row { font-size: 16px; color: #FFD700; font-weight: 900; }
    .card { background: #181818; border-radius: 12px; padding: 16px; color: #FFD700; font-size: 14px; margin: 24px 0 0 0; }
    .card-title { font-size: 13px; color: #FFD700; font-weight: 700; margin-bottom: 4px; }
    .card-content { color: #fff; font-size: 14px; }
    .footer { background: #181818; color: #FFD700; text-align: center; padding: 32px 0 0 0; border-radius: 0 0 18px 18px; }
    .address { color: #fff; font-size: 13px; margin: 18px 0 0 0; }
    .footer-note { color: #888; font-size: 12px; margin: 18px 0 0 0; }
    @media (max-width: 650px) {
      .container { max-width: 98vw; }
      .promise-row { flex-direction: column; gap: 10px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <img class="logo" src="{{logoUrl}}" alt="eShopper Luxe Logo" />
      <div class="order-title">ORDER CONFIRMED</div>
      <div class="order-id">Order ID: {{orderId}}</div>
      <div class="order-date">{{orderDate}}</div>
    </div>
    <div class="banner">ORDER CONFIRMED</div>
    <div class="greeting">Hi {{customerName}},<br>Your order has been <span style="color:#1ec773;font-weight:700;">confirmed</span> and is now being prepared by our expert team. Every item will undergo our strict 10-point quality inspection before dispatch.</div>
    <div class="arrival-box">EXPECTED ARRIVAL: {{expectedArrival}}</div>
    <div class="promise-row">
      <div class="promise">
        <span class="promise-icon">🔍</span>
        <div class="promise-title">Quality Check</div>
        <div class="promise-desc">10-point inspection by experts</div>
      </div>
      <div class="promise">
        <span class="promise-icon">📦</span>
        <div class="promise-title">Premium Packaging</div>
        <div class="promise-desc">Eco-friendly luxury boxes</div>
      </div>
      <div class="promise">
        <span class="promise-icon">🛡️</span>
        <div class="promise-title">100% Authentic</div>
        <div class="promise-desc">Guaranteed genuine products</div>
      </div>
    </div>
    <div class="summary-title">ORDER DETAILS</div>
    <table class="summary-table">
      <tr>
        <th>ITEM</th>
        <th>DETAILS</th>
        <th>QTY</th>
        <th>PRICE</th>
      </tr>
      {{#each items}}
      <tr>
        <td><img class="product-img" src="{{imageUrl}}" alt="{{name}}" /></td>
        <td>{{name}}<br><span style="color:#FFD700; font-size:12px;">Size: {{size}}</span><br><span style="color:#fff; font-size:12px;">Color: {{color}}</span></td>
        <td>{{quantity}}</td>
        <td>&#8377;{{subtotal}}</td>
      </tr>
      {{/each}}
      <tr class="total-row">
        <td colspan="3" style="text-align:right;">Total Paid</td>
        <td>&#8377;{{totalPaid}}</td>
      </tr>
    </table>
    <div class="card">
      <div class="card-title">SHIPPING ADDRESS</div>
      <div class="card-content">{{shippingAddress}}</div>
    </div>
    <div class="footer">
      <div class="address">{{companyAddress}}</div>
      <div class="footer-note">* This is an order confirmation, not a Tax Invoice. Tax Invoice will be provided upon delivery.</div>
    </div>
  </div>
</body>
</html>
