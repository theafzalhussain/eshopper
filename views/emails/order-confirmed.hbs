<!-- Order Confirmed Email Template (Table-based, Responsive) -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Order Confirmed - eShopper Luxe</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
</head>
<body style="margin:0; padding:0; background:#181818; color:#fff; font-family:'Segoe UI',Arial,sans-serif;">
  <table width="100%" bgcolor="#181818" cellpadding="0" cellspacing="0" style="padding:0; margin:0;">
    <tr>
      <td align="center">
        <table width="480" cellpadding="0" cellspacing="0" style="background:#232323; border-radius:12px; margin:32px 0; box-shadow:0 2px 16px #00000033;">
          <!-- Header -->
          <tr>
            <td style="padding:24px 32px 8px 32px; text-align:left;">
              <img src="https://yourdomain.com/logo.png" alt="eShopper Luxe" style="height:28px; margin-bottom:12px;">
              <div style="font-size:13px; color:#fff; text-align:right; float:right;">
                <span style="background:#1a3d1a; color:#b6ffb6; font-size:13px; padding:4px 12px; border-radius:6px; font-weight:600;">&#10003; CONFIRMED</span>
              </div>
            </td>
          </tr>
          <!-- Order Confirmed Banner -->
          <tr>
            <td style="background:#1bbf4c; color:#fff; text-align:center; font-size:22px; font-weight:600; padding:18px 0 10px 0; letter-spacing:1px;">
              <span style="font-size:22px;">🎉</span> ORDER CONFIRMED!
              <div style="font-size:13px; color:#eaffea; font-weight:400; margin-top:2px;">
                Order #{{orderId}} | {{orderDate}}
              </div>
            </td>
          </tr>
          <!-- Greeting -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:left;">
              <div style="font-size:18px; font-weight:600; margin-bottom:6px;">Hi {{customerName}} <span style="font-size:18px;">👋</span></div>
              <div style="font-size:14px; color:#ccc;">
                Your order has been <span style="color:#1bbf4c; font-weight:600;">confirmed</span> and is now being prepared by our expert team. Every item will undergo our strict 10-point quality inspection before dispatch.
              </div>
            </td>
          </tr>
          <!-- Expected Arrival -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:center;">
              <div style="background:#ffd700; color:#232323; font-size:20px; font-weight:700; border-radius:8px; padding:16px 0 8px 0;">
                EXPECTED ARRIVAL<br>
                <span style="font-size:28px; color:#232323;">{{expectedDate}}</span>
                <div style="font-size:13px; color:#232323; font-weight:400; margin-top:2px;">3-5 Business Days</div>
              </div>
            </td>
          </tr>
          <!-- Luxe Promise -->
          <tr>
            <td style="padding:24px 32px 0 32px;">
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#143d1a; border-radius:8px;">
                <tr>
                  <td colspan="3" style="color:#ffd700; font-size:15px; font-weight:600; text-align:center; padding:12px 0 0 0;">
                    ✨ THE LUXE PROMISE
                  </td>
                </tr>
                <tr>
                  <td align="center" style="padding:16px 0;">
                    <img src="https://img.icons8.com/ios-filled/50/ffd700/inspection.png" width="32" style="display:block; margin:0 auto 6px auto;">
                    <div style="color:#fff; font-size:13px; font-weight:600;">Quality Check</div>
                    <div style="color:#b6b6b6; font-size:12px;">10-point inspection by experts</div>
                  </td>
                  <td align="center" style="padding:16px 0;">
                    <img src="https://img.icons8.com/ios-filled/50/ffd700/box.png" width="32" style="display:block; margin:0 auto 6px auto;">
                    <div style="color:#fff; font-size:13px; font-weight:600;">Premium Packaging</div>
                    <div style="color:#b6b6b6; font-size:12px;">Eco-friendly luxury boxes</div>
                  </td>
                  <td align="center" style="padding:16px 0;">
                    <img src="https://img.icons8.com/ios-filled/50/ffd700/shield.png" width="32" style="display:block; margin:0 auto 6px auto;">
                    <div style="color:#fff; font-size:13px; font-weight:600;">100% Authentic</div>
                    <div style="color:#b6b6b6; font-size:12px;">Guaranteed genuine products</div>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Order Details -->
          <tr>
            <td style="padding:24px 32px 0 32px;">
              <div style="color:#ffd700; font-size:15px; font-weight:600; margin-bottom:8px;">ORDER DETAILS</div>
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#232323; border-radius:8px;">
                <tr style="color:#ffd700; font-size:13px;">
                  <th align="left" style="padding:8px 0;">ITEM</th>
                  <th align="left" style="padding:8px 0;">DETAILS</th>
                  <th align="center" style="padding:8px 0;">QTY</th>
                  <th align="right" style="padding:8px 0;">PRICE</th>
                </tr>
                <tr style="background:#181818;">
                  <td style="padding:8px 0;">
                    <img src="{{productImage}}" alt="Product" style="width:48px; border-radius:6px;">
                  </td>
                  <td style="padding:8px 0;">
                    <div style="font-weight:600; color:#fff;">{{productName}}</div>
                    <div style="font-size:12px; color:#ccc;">Size: {{size}}</div>
                    <div style="font-size:12px; color:#ccc;">Color: {{color}}</div>
                  </td>
                  <td align="center" style="padding:8px 0; color:#fff;">{{qty}}</td>
                  <td align="right" style="padding:8px 0; color:#fff;">₹{{price}}</td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Price Summary -->
          <tr>
            <td style="padding:18px 32px 0 32px;">
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="color:#b6b6b6; font-size:14px;">Item Price</td>
                  <td align="right" style="color:#fff; font-size:14px;">₹{{itemPrice}}</td>
                </tr>
                <tr>
                  <td style="color:#b6b6b6; font-size:14px;">Shipping Charges</td>
                  <td align="right" style="color:#fff; font-size:14px;">₹{{shipping}}</td>
                </tr>
                <tr>
                  <td style="color:#b6b6b6; font-size:14px;">GST (Included)</td>
                  <td align="right" style="color:#fff; font-size:14px;">₹{{gst}}</td>
                </tr>
                <tr>
                  <td style="color:#ffd700; font-size:16px; font-weight:600; padding-top:8px;">Total Amount Paid</td>
                  <td align="right" style="color:#ffd700; font-size:16px; font-weight:600; padding-top:8px;">₹{{total}}</td>
                </tr>
                <tr>
                  <td style="color:#b6b6b6; font-size:13px;">Payment Mode:</td>
                  <td align="right" style="color:#b6ffb6; font-size:13px;">{{paymentMode}}</td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Shipping & Billing -->
          <tr>
            <td style="padding:18px 32px 0 32px;">
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td valign="top" width="50%" style="padding-right:8px;">
                    <table width="100%" style="background:#232323; border-radius:8px;">
                      <tr>
                        <td style="color:#ffd700; font-size:13px; font-weight:600; padding:8px 0 0 0;">&#128205; SHIPPING TO</td>
                      </tr>
                      <tr>
                        <td style="color:#fff; font-size:14px; font-weight:600;">{{customerName}}</td>
                      </tr>
                      <tr>
                        <td style="color:#b6b6b6; font-size:13px;">
                          {{address}}<br>
                          {{city}}, {{state}} {{zip}}<br>
                          Phone: {{phone}}
                        </td>
                      </tr>
                    </table>
                  </td>
                  <td valign="top" width="50%">
                    <table width="100%" style="background:#232323; border-radius:8px;">
                      <tr>
                        <td style="color:#ffd700; font-size:13px; font-weight:600; padding:8px 0 0 0;">BILLING INFO</td>
                      </tr>
                      <tr>
                        <td style="color:#fff; font-size:14px; font-weight:600;">{{customerName}}</td>
                      </tr>
                      <tr>
                        <td style="color:#b6b6b6; font-size:13px;">
                          Email: {{email}}<br>
                          Transaction ID: {{transactionId}}
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Track Order & Receipt Buttons -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:center;">
              <a href="{{trackOrderUrl}}" style="background:#1bbf4c; color:#fff; font-size:16px; font-weight:600; text-decoration:none; padding:12px 32px; border-radius:8px; display:inline-block; margin-bottom:8px;">TRACK YOUR ORDER</a>
              <br>
              <a href="{{receiptUrl}}" style="background:#232323; color:#ffd700; font-size:15px; font-weight:600; text-decoration:none; padding:10px 24px; border-radius:6px; border:1px solid #ffd700; display:inline-block;">&#128196; VIEW RECEIPT</a>
            </td>
          </tr>
          <!-- Luxe Community & Social -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:center;">
              <div style="color:#ffd700; font-size:15px; font-weight:600;">Join our 50,000+ Luxe community</div>
              <div style="color:#ffd700; font-size:22px; margin:8px 0;">★★★★★</div>
              <a href="{{instagramUrl}}" style="background:#ff2d55; color:#fff; font-size:15px; font-weight:600; text-decoration:none; padding:10px 24px; border-radius:6px; display:inline-block;">&#128247; Follow us on Instagram</a>
            </td>
          </tr>
          <!-- Need Assistance -->
          <tr>
            <td style="padding:24px 32px 0 32px; text-align:center;">
              <div style="color:#b6b6b6; font-size:14px; margin-bottom:8px;">Need Assistance?</div>
              <a href="{{whatsappUrl}}" style="background:#25d366; color:#232323; font-size:15px; font-weight:600; text-decoration:none; padding:10px 24px; border-radius:6px; margin-right:8px; display:inline-block;">WhatsApp Us</a>
              <a href="{{emailUrl}}" style="background:#232323; color:#fff; font-size:15px; font-weight:600; text-decoration:none; padding:10px 24px; border-radius:6px; border:1px solid #fff; display:inline-block;">Email Support</a>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td style="padding:24px 0 0 0; text-align:center; color:#b6b6b6; font-size:12px;">
              © 2026 eShopper Luxe. All rights reserved.<br>
              Shop 3, Sahid Marg, Near Power, Lucknow - 226001, UP, India<br>
              GSTIN: 09XXXX0134ZX1ZS | CIN: U51909UP2020PTC123456<br>
              <a href="{{privacyUrl}}" style="color:#ffd700; text-decoration:none;">Privacy</a> | <a href="{{termsUrl}}" style="color:#ffd700; text-decoration:none;">Terms</a> | <a href="{{unsubscribeUrl}}" style="color:#ffd700; text-decoration:none;">Unsubscribe</a>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>