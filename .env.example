# MongoDB Atlas
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority"

# Brevo
BREVO_API_KEY="your_brevo_api_key"

# WhatsApp (Evolution API on Railway)
EVOLUTION_API_URL="https://your-evolution-instance.up.railway.app"
WHATSAPP_TOKEN="your_evolution_api_key"
WHATSAPP_INSTANCE="eshopper_bot"

# Cloudinary
CLOUD_NAME="your_cloud_name"
CLOUD_API_KEY="your_cloud_api_key"
CLOUD_API_SECRET="your_cloud_api_secret"

# Server
PORT=10000
FRONTEND_URL="https://your-vercel-app.vercel.app"

# Datadog (Frontend)
REACT_APP_DATADOG_APP_ID=""
REACT_APP_DATADOG_CLIENT_TOKEN=""
REACT_APP_DATADOG_SITE="us5.datadoghq.com"
REACT_APP_DATADOG_SERVICE="eshopper-frontend"
REACT_APP_DATADOG_ENV="production"
REACT_APP_DATADOG_VERSION="1.0.0"
